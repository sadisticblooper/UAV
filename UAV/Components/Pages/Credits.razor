@page "/credits"
@layout EmptyLayout

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

<style>
    * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
    }

    body, .credits-root {
        background-color: #1e1e1e;
        color: #cccccc;
        font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;
        font-size: 1rem;
        line-height: 1.6;
    }

    .credits-root {
        width: 100vw;
        min-height: 100vh;
        padding: 2.5rem;
        display: flex;
        flex-direction: column;
        align-items: flex-start;
        justify-content: flex-start;
    }

    .back-btn {
        margin-bottom: 2rem;
        color: #aaaaaa;
        background: transparent;
        border: 1px solid #444444;
        padding: 0.4rem 1.2rem;
        font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;
        font-size: 0.9rem;
        cursor: pointer;
        letter-spacing: 0.3px;
        display: inline-flex;
        align-items: center;
        gap: 8px;
        border-radius: 4px;
        transition: all 0.2s ease;
        text-decoration: none;
    }

    .back-btn:hover {
        background: rgba(255, 255, 255, 0.05);
        color: #ffffff;
        border-color: #666666;
    }

    .app-title {
        font-size: 2.2rem;
        font-weight: 300;
        color: #ffffff;
        letter-spacing: 0.3em;
        margin-bottom: 0.3rem;
    }

    .app-subtitle {
        font-size: 0.85rem;
        color: #888888;
        letter-spacing: 0.15em;
        text-transform: uppercase;
        margin-bottom: 2.5rem;
    }

    .credits-section {
        margin-bottom: 2rem;
        border-left: 2px solid #3a3a3a;
        padding-left: 1.5rem;
    }

    .credits-section h3 {
        font-size: 0.75rem;
        font-weight: 600;
        color: #777777;
        text-transform: uppercase;
        letter-spacing: 0.15em;
        margin-bottom: 0.75rem;
    }

    .credits-section p {
        margin: 0.4rem 0;
        color: #cccccc;
        font-size: 0.95rem;
    }

    .credits-section strong {
        color: #ffffff;
        font-weight: 500;
    }

    .discord-tag {
        color: #7289da;
    }

    .discord-tag i {
        margin-right: 6px;
    }

    .credits-section a {
        color: #7289da;
        text-decoration: none;
        border-bottom: 1px dotted #7289da;
        transition: all 0.2s ease;
    }

    .credits-section a:hover {
        color: #ffffff;
        border-bottom-color: #ffffff;
    }

    .credits-footer {
        margin-top: 3rem;
        padding-top: 1.5rem;
        border-top: 1px solid #333333;
        font-size: 0.8rem;
        color: #666666;
        max-width: 600px;
        line-height: 1.8;
    }

    .credits-footer strong {
        color: #888888;
        font-weight: 500;
    }
</style>

<div class="credits-root">

    <a href="/" class="back-btn"><i class="fa-solid fa-arrow-left"></i> Back</a>

    <div class="app-title">UAV</div>
    <div class="app-subtitle">Unity Asset Viewer</div>

    <div class="credits-section">
        <h3>Development</h3>
        <p>
            Developed by <strong>Nexora  </strong>
            <span class="discord-tag"><i class="fa-brands fa-discord"></i> @@ftw.sadistic</span>
        </p>
    </div>

    <div class="credits-section">
        <h3>Libraries &amp; Tools</h3>
        <p>
            <strong>AssetTools.NET</strong> by Nesark1
        </p>
        
    </div>

    <div class="credits-section">
        <h3>Todo</h3>
        <p>
            Asset editing.<br>
         
        </p>
    </div>

    <div class="credits-footer">
        Contributions and feedback are welcome.<br>
     
    </div>

</div>