@using UAV.Services
@using System.IO.Compression

@if (Result?.Success == true)
{
    <div class="texture-preview">
        <div class="preview-info">@Result.Width x @Result.Height @(Result.FormatId > 0 ? $"[{Result.FormatName} #{Result.FormatId}]" : "")</div>
        <img src="@ImageDataUrl" alt="Texture Preview" style="max-width:100%; border:1px solid #555;" />
    </div>
}
else if (!string.IsNullOrEmpty(Result?.Error))
{
    <div class="preview-error">Decode failed: @Result.Error</div>
}
else if (Loading)
{
    <div class="preview-loading">Decoding...</div>
}

@code {
    [Parameter] public TextureDecodeResult? Result { get; set; }
    [Parameter] public bool Loading { get; set; }
    [Parameter] public string? AssetName { get; set; }

    private string? ImageDataUrl { get; set; }

    protected override void OnParametersSet()
    {
        ImageDataUrl = null;
        if (Result?.Success == true && Result.RgbaData != null)
        {
            try
            {
                var rgba = Result.RgbaData;
                int w = Result.Width, h = Result.Height;
                if (rgba.Length < w * h * 4) return;
                var png = EncodePng(rgba, w, h);
                ImageDataUrl = $"data:image/png;base64,{Convert.ToBase64String(png)}";
            }
            catch { ImageDataUrl = null; }
        }
    }

    public static byte[] EncodePng(byte[] rgba, int width, int height)
    {
        using var file = new MemoryStream();
        file.Write(new byte[] { 137, 80, 78, 71, 13, 10, 26, 10 });
        WriteChunk(file, "IHDR", w =>
        {
            WriteU32BE(w, (uint)width);
            WriteU32BE(w, (uint)height);
            w.WriteByte(8); w.WriteByte(6); w.WriteByte(0); w.WriteByte(0); w.WriteByte(0);
        });
        using var scanlines = new MemoryStream();
        using (var zlib = new ZLibStream(scanlines, CompressionLevel.Fastest, leaveOpen: true))
        {
            int stride = width * 4;
            for (int y = 0; y < height; y++)
            {
                zlib.WriteByte(0);
                zlib.Write(rgba, y * stride, stride);
            }
        }
        WriteChunk(file, "IDAT", w => w.Write(scanlines.ToArray()));
        WriteChunk(file, "IEND", _ => { });
        return file.ToArray();
    }

    private static void WriteChunk(Stream dest, string type, Action<Stream> writeData)
    {
        using var body = new MemoryStream();
        body.Write(System.Text.Encoding.ASCII.GetBytes(type));
        writeData(body);
        var bodyArr = body.ToArray();
        var dataOnly = bodyArr[4..];
        WriteU32BE(dest, (uint)dataOnly.Length);
        dest.Write(bodyArr);
        WriteU32BE(dest, Crc32(bodyArr));
    }

    private static void WriteU32BE(Stream s, uint v)
    {
        s.WriteByte((byte)(v >> 24)); s.WriteByte((byte)(v >> 16));
        s.WriteByte((byte)(v >> 8));  s.WriteByte((byte)v);
    }

    private static uint Crc32(byte[] data)
    {
        uint crc = 0xFFFFFFFF;
        foreach (byte b in data) { crc ^= b; for (int i = 0; i < 8; i++) crc = (crc & 1) != 0 ? (crc >> 1) ^ 0xEDB88320 : crc >> 1; }
        return crc ^ 0xFFFFFFFF;
    }
}
